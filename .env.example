# ─────────────────────────────────────────────────────────────────────────────
# Velocitype environment. Copy to .env, then run ./secrets/keygen.sh.
#   cp .env.example .env && ./secrets/keygen.sh && docker compose up --build
# The defaults below are DEV-ONLY. Change every password before any real deploy.
# ─────────────────────────────────────────────────────────────────────────────

ENV=development

# ── Postgres ────────────────────────────────────────────────────────────────
# Superuser password (cluster admin, used only by the db container itself).
POSTGRES_SUPERUSER_PASSWORD=dev_superuser_change_me
# Least-privilege application role (owns only the velocitype database).
POSTGRES_DB=velocitype
POSTGRES_APP_USER=velocitype_app
POSTGRES_APP_PASSWORD=dev_app_change_me

# App connection string (async driver). Host "db" is the compose service name.
DATABASE_URL=postgresql+asyncpg://velocitype_app:dev_app_change_me@db:5432/velocitype

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=dev_redis_change_me
REDIS_URL=redis://:dev_redis_change_me@redis:6379/0

# ── Auth / cookies ─────────────────────────────────────────────────────────────
# JWT keys are generated as PEM files by ./secrets/keygen.sh (not stored here).
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# Set true in production (HTTPS). Dev override forces this to false over plain HTTP.
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated explicit allowlist. No wildcard in production.
CORS_ORIGINS=http://localhost:5173,http://localhost

# ── Ollama (local LLM coaching) ───────────────────────────────────────────────
# The coaching feature runs entirely against the local Ollama service — no
# external LLM API. The model is pulled into a volume on first `up` (several GB).
OLLAMA_MODEL=qwen3.5:4b
# Point elsewhere to use a host Ollama instead of the bundled service, e.g.
# OLLAMA_BASE_URL=http://host.docker.internal:11434 (host must listen on 0.0.0.0).
OLLAMA_BASE_URL=http://ollama:11434

# ── Caddy ─────────────────────────────────────────────────────────────────────
# ":80" for local HTTP. In production set to your domain, e.g. velocitype.example.com
SITE_ADDRESS=:80
# Host ports Caddy binds. Change if 80/443 are already in use on the host.
HTTP_PORT=80
HTTPS_PORT=443
